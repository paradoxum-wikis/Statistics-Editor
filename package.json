{
  "name": "tds-stats-editor",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx vite preview",
    "prepare": "bunx svelte-kit sync || true",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "bunx prettier --write ."
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "bits-ui": "^2.18.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-lucide-preprocess": "^1.5.0"
  },
  "dependencies": {
    "@bhsd/codemirror-wikitext": "^0.10.0",
    "@lucide/svelte": "^1.24.0",
    "codemirror": "^6.0.2",
    "mediawiki-expr": "^0.0.2",
    "mediawiki-file-url": "^0.4.0"
  }
}
