{
  "name": "tds-stats-editor",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx vite preview",
    "prepare": "bunx svelte-kit sync || true",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "bunx prettier --write ."
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "bits-ui": "^2.16.4",
    "prettier": "^3.8.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@lucide/svelte": "^0.576.0",
    "mediawiki-file-url": "^0.3.1",
    "wikistxr": "^0.0.12"
  }
}
